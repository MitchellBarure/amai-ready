{
  "name": "server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@elysiajs/cors": "^1.4.2",
    "better-auth": "^1.6.23",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "scripts": {
    "dev": "bun --watch src/index.js",
    "start": "bun src/index.js",
    "test": "vitest run",
    "auth:generate": "bunx auth@latest generate --config ./src/lib/auth.js --output ./src/db/auth-schema.js --yes",
    "db:generate": "drizzle-kit generate",
